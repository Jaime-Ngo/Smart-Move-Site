---
import Layout from '../layouts/Layout.astro';

const testimonials = [
  {
    name: "Joe B.",
    stars: 5,
    date: "3 weeks ago",
    text: "I'd give Smart Move six stars if it were an option. Jay and his team are professional, courteous and respectful. They show up on-time and finish on-time. Their rates are quite competitive and always match their quoted price. This is our second time using Smart Move. Our daughter will be moving soon, and there will be no other call than Smart Move.",
    source: "Google"
  },
  {
    name: "Mari F.",
    stars: 5,
    date: "November 2025",
    text: "The crew didn't just show up on time, they showed up early and ready to go. We had a smooth and easy walk through of all of the pieces that needed to go. They were very attentive and meticulous about how to handle the furniture carefully. Professional, quick, and focused on getting the job done. Highly recommend and will use this team again.",
    source: "Moving Help®"
  },
  {
    name: "Irene W.",
    stars: 5,
    date: "4 months ago",
    text: "Jay and Fran did an amazing job packing my UBoxes from my storage unit. I've moved numerous times including across the country four times — they absolutely did the best job packing, barely leaving room for a toothpick. They cared for my boxes and furniture by tenderly wrapping everything in plastic and blankets. Nothing was damaged during transport.",
    source: "Google"
  },
  {
    name: "Bobbii M.",
    stars: 5,
    date: "January 2026",
    text: "Jay and Jonathan were wonderful. Jay went over and beyond even before the move to help us. He is so professional and so hardworking. We give this company top ratings.",
    source: "Moving Help®"
  },
  {
    name: "Joyce S.",
    stars: 5,
    date: "November 2025",
    text: "Great communication and professionalism, hard working, and truly went above and beyond. Second time I've used their services and would highly recommend to anyone.",
    source: "Moving Help®"
  },
  {
    name: "Olivia P.",
    stars: 5,
    date: "November 2025",
    text: "Jay and his colleague were fantastic — attentive with our belongings and super courteous. The communication process was great from booking all the way to finish. Highly recommend.",
    source: "Moving Help®"
  },
  {
    name: "Aaron S.",
    stars: 5,
    date: "August 2025",
    text: "Super professional and hard working. Showed up with their own equipment and knocked out everything. 10 out of 10.",
    source: "Moving Help®"
  },
  {
    name: "Samuel B.",
    stars: 5,
    date: "January 2026",
    text: "They were fantastic — helped us clear off the sidewalk and parking spot with all the snow and ice so they could move things safely. That kind of initiative is exactly what sets this team apart. Would use them again without question.",
    source: "Moving Help®"
  },
  {
    name: "Joyana H.",
    stars: 5,
    date: "January 2026",
    text: "Jay and Jonathan were great — thoughtful, prompt, and communicative. Highly recommend.",
    source: "Moving Help®"
  },
];
---
---

<Layout title="Testimonials" description="Read 150+ verified reviews from Smart Move clients on U-Haul Moving Help and Google.">

  <section class="test-hero section">
    <div class="container">
      <span class="eyebrow">What Clients Say</span>
      <h1>Testimonials</h1>
      <p class="test-intro">We let our clients speak for us. Over 150 verified reviews across Moving Help® and Google — consistent, honest feedback from real moves.</p>
      <div class="test-hero-links">
        <a href="https://www.uhaul.com/MovingHelp/Reviews/114383/0/?modal=True" target="_blank" rel="noopener" class="btn-primary">Read 150+ Moving Help® Reviews</a>
        <a href="https://share.google/y9Ng5XgdrkCePuRtf" target="_blank" rel="noopener" class="btn-outline">View Google Reviews</a>
      </div>
    </div>
  </section>

  <section class="test-grid-section section">
    <div class="container">
      <div class="test-grid">
        {testimonials.map((t) => (
          <div class="test-card">
            <div class="test-card-top">
              <div class="test-stars">{"★".repeat(t.stars)}</div>
              <span class="test-source">{t.source}</span>
            </div>
            <p class="test-text">"{t.text}"</p>
            <div class="test-card-bottom">
              <span class="test-name">{t.name}</span>
              <span class="test-date">{t.date}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="test-cta section">
    <div class="container" style="text-align: center;">
      <span class="eyebrow">See Every Review</span>
      <h2>150+ Verified Reviews and Counting</h2>
      <div style="display: flex; gap: 1rem; justify-content: center; margin-top: 2.5rem; flex-wrap: wrap;">
        <a href="https://www.uhaul.com/MovingHelp/Reviews/114383/0/?modal=True" target="_blank" rel="noopener" class="btn-primary">Read All on Moving Help®</a>
        <a href="/contact" class="btn-outline">Book Your Move</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .test-hero {
    padding-top: 10rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
  }

  .test-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin-bottom: 1rem;
  }

  .test-intro {
    color: var(--white-dim);
    max-width: 560px;
    margin-bottom: 2.5rem;
    font-size: 1rem;
    line-height: 1.8;
  }

  .test-hero-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .test-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .test-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.3s ease;
  }

  .test-card:hover {
    border-color: var(--border-strong);
  }

  .test-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .test-stars {
    color: var(--gold);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
  }

  .test-source {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--white-dim);
    background: var(--surface);
    padding: 0.2rem 0.6rem;
  }

  .test-text {
    font-size: 0.88rem;
    color: var(--white-dim);
    line-height: 1.8;
    font-style: italic;
    flex: 1;
  }

  .test-card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--border);
    padding-top: 0.75rem;
  }

  .test-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--white);
  }

  .test-date {
    font-size: 0.75rem;
    color: var(--white-dim);
  }

  .test-cta {
    background: var(--surface);
    border-top: 1px solid var(--border);
  }

  .test-cta h2 {
    font-size: clamp(1.8rem, 3.5vw, 2.75rem);
    margin-bottom: 1rem;
  }

  .test-cta p {
    color: var(--white-dim);
    max-width: 480px;
    margin: 0 auto;
    font-size: 0.95rem;
  }

  @media (max-width: 900px) {
    .test-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .test-grid { grid-template-columns: 1fr; }
  }
</style>