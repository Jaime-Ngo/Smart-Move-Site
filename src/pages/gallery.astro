---

<Layout title="Gallery" description="Real Smart Move jobs — loading, packing, and hauling across Baltimore and beyond.">

  <section class="gallery-hero">
    <div class="container">
      <span class="eyebrow">Our Work</span>
      <h1>Gallery</h1>
      <p>Real jobs. Real results. Every photo is from an actual Smart Move relocation.</p>
    </div>
  </section>

  <section class="gallery-section">
    <div class="gallery-grid">
      {photos.map((photo, index) => (
        <button
          class="gallery-item"
          data-src={photo.src}
          data-alt={photo.alt}
          data-index={String(index)}
          aria-label={photo.alt}
        >
          <img src={photo.src} alt={photo.alt} loading="lazy" />
        </button>
      ))}
    </div>
  </section>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" aria-hidden="true">
    <div class="lb-backdrop" id="lbBackdrop"></div>
    <button class="lb-close" id="lbClose" aria-label="Close">✕</button>
    <button class="lb-prev" id="lbPrev" aria-label="Previous">‹</button>
    <button class="lb-next" id="lbNext" aria-label="Next">›</button>
    <div class="lb-content">
      <img id="lbImg" src="" alt="" />
      <p id="lbCaption"></p>
      <span id="lbCounter"></span>
    </div>
  </div>

  <section class="gallery-cta">
    <div class="container" style="text-align:center">
      <span class="eyebrow">Like What You See?</span>
      <h2>Let's Get to Work</h2>
      <div class="cta-buttons">
        <a href="/contact" class="btn-primary">Request a Quote</a>
        <a href="/testimonials" class="btn-outline">Read Reviews</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .gallery-hero {
    padding: 9rem 0 3rem;
    border-bottom: 1px solid var(--border);
  }
  .gallery-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin: 0.5rem 0 1rem;
  }
  .gallery-hero p {
    color: var(--white-dim);
    max-width: 480px;
    line-height: 1.8;
  }

  .gallery-section {
    padding: 0;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3px;
    background: #111;
  }

  .gallery-item {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #1a1a1a;
    border: none;
    cursor: pointer;
    padding: 0;
    display: block;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease, opacity 0.3s ease;
    opacity: 1;
  }

  .gallery-item:hover img {
    transform: scale(1.06);
    opacity: 0.85;
  }

  /* LIGHTBOX */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }
  .lightbox.open {
    opacity: 1;
    pointer-events: all;
  }
  .lb-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.94);
    cursor: pointer;
  }
  .lb-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    max-width: 90vw;
    max-height: 90vh;
  }
  .lb-content img {
    max-width: 90vw;
    max-height: 80vh;
    object-fit: contain;
    display: block;
    transition: opacity 0.15s ease;
  }
  #lbCaption {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.6);
    text-align: center;
    font-style: italic;
    margin: 0;
  }
  #lbCounter {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--gold, #C9962A);
    text-transform: uppercase;
  }
  .lb-close {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    z-index: 2;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.25);
    color: #fff;
    font-size: 1rem;
    width: 38px;
    height: 38px;
    border-radius: 2px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, color 0.2s;
  }
  .lb-close:hover { border-color: var(--gold, #C9962A); color: var(--gold, #C9962A); }

  .lb-prev,
  .lb-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    background: rgba(0,0,0,0.6);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    font-size: 2.5rem;
    width: 48px;
    height: 72px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    transition: border-color 0.2s, color 0.2s;
  }
  .lb-prev { left: 1rem; }
  .lb-next { right: 1rem; }
  .lb-prev:hover,
  .lb-next:hover { border-color: var(--gold, #C9962A); color: var(--gold, #C9962A); }

  .gallery-cta {
    padding: 6rem 0;
    border-top: 1px solid var(--border);
    background: var(--surface, #111);
  }
  .gallery-cta h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0.5rem 0 0;
  }
  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  @media (max-width: 1024px) {
    .gallery-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 640px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .lb-prev { left: 0.25rem; }
    .lb-next { right: 0.25rem; }
  }
</style>

